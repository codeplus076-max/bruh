# ========================================
# UPCHAAR - Environment Configuration Template
# ========================================
# Rename this file to `.env` or `.env.local`. 
# DO NOT commit real API keys into version control!

# --- OpenAI Environment ---
# Required for Medical Diagnosis & Suggestion Engine
OPENAI_API_KEY=sk-your-openai-api-key-here

# --- Google Maps Environment ---
# Required for locating nearby hospitals
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-browser-key-here

# --- Firebase Environment ---
# Required for Auth & Database connections (Frontend)
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-app.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-app.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef

# --- Application APIs ---
# Use this when running components locally or linking Vercel to Render
NEXT_PUBLIC_API_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:3000,https://your-production-domain.com
